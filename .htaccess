RewriteEngine On
RewriteBase /plvsystem/

# Prevent loops by checking if we are already at index.php
RewriteCond %{REQUEST_URI} ^/plvsystem/index\.php [NC]
RewriteRule .* - [L]

# If the requested name is not a real directory
RewriteCond %{REQUEST_FILENAME} !-d
# AND if the requested name is not a real file
RewriteCond %{REQUEST_FILENAME} !-f
# Redirect everything else to index.php
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]